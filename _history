tic\"><field name=\"OP\">ADD</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"Np4io29Uh}=$db~pMfcB\">index3</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">1</field></shadow></value></block></value></block></value><next><block type=\"variables_change\"><field name=\"VAR\" id=\"EY)T/6#7x?Y}TZ9Ko.0O\">紅外線和</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\":wQb^;~/n[!XLY!aVk[~\">NMZ_IR</field></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\")?4x7yKIsC?62,HqE;[i\">LinePOS</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">DIVIDE</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"9qQYb{A8S}v`r*#w4weM\">權重和</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"EY)T/6#7x?Y}TZ9Ko.0O\">紅外線和</field></block></value></block></value></block></next></block></next></block></next></block></statement></block></next></block></next></block></statement></block><block type=\"function_definition\" x=\"-939\" y=\"330\"><mutation name=\"紅外線取樣\" functionid=\"t~k,a,Y2b;)Dv+?3c8DR\"></mutation><field name=\"function_name\">紅外線取樣</field><statement name=\"STACK\"><block type=\"pxt_controls_for\"><value name=\"VAR\"><block type=\"variables_get_reporter\" deletable=\"false\"><field name=\"VAR\" id=\"/r5|=r19iCknpBWgg{;[\">index</field></block></value><value name=\"TO\"><shadow type=\"math_whole_number\"><field name=\"NUM\">6</field></shadow></value><statement name=\"DO\"><block type=\"variables_set\"><field name=\"VAR\" id=\":wQb^;~/n[!X